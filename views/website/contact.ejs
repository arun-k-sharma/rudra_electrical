<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head',{title:"Contact"}) %>

    <body>
        <%- include('../partials/navbar') %>
            <main class="container">
                <section class="page-hero">
                    <div class="container">
                        <span class="section-badge">
                            📞 Contact Us
                        </span>
                        <h1>Get In Touch</h1>
                        <p>
                            Need electrical services or have questions about our products?
                            We're always happy to help.
                        </p>
                    </div>
                </section>
                <section class="contact">
                    <div class="container">
                        <div class="contact-wrapper">
                            
                            <!-- Contact Info -->

                            <div class="contact-info">
                                <div class="info-card">
                                    <h3>📍 Address</h3>
                                    <p>
                                        Rudra Electrical<br>
                                        Shahkhajura Gate, Mehnagar Road Azamgarh, Uttar Pradesh
                                    </p>
                                </div>
                                <div class="info-card">
                                    <h3>📞 Phone</h3>
                                    <p>
                                        +91 8090801286
                                    </p>
                                </div>
                                <div class="info-card">
                                    <h3>📧 Email</h3>
                                    <p>
                                        ds2286422@gmail.com
                                    </p>
                                </div>
                                <div class="info-card">
                                    <h3>🕒 Working Hours</h3>
                                    <p>
                                        Monday - Saturday<br>
                                        9:00 AM - 8:00 PM
                                    </p>
                                </div>
                            </div>

                            <!-- Contact Form -->

                            <div class="contact-form">
                                <h2>Send Message (coming soon)</h2>
                                <form>
                                    <input type="text" placeholder="Full Name" disabled>
                                    <input type="tel" placeholder="Phone Number" disabled>
                                    <input type="text" placeholder="Subject" disabled>
                                    <textarea rows="6" placeholder="Write your message..." disabled></textarea>
                                    <button type="submit" class="btn btn-primary" disabled>
                                        Send Message
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="map">
                    <div class="container">
                        <h2>Find Us</h2>
                        <div class="map-box">
                            <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d230.2989020039716!2d83.13760749827898!3d25.948133288498276!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3991b91366f47d1d%3A0xea13934dcd87982!2sW4XQ%2B725%2C%20Mehnagar%20Azamgarh%20Sarayrani%20Jaunpur%20Marg%2C%20Mustafabad%2C%20Uttar%20Pradesh%20276204!5e1!3m2!1sen!2sin!4v1783162990285!5m2!1sen!2sin" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
                        </div>
                    </div>
                </section>
            </main>

            <%- include('../partials/footer') %>
            <script src="/js/navbar.js"></script>

    </body>

</html>