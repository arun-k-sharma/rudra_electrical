<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head',{title:"Services"}) %>

    <body>
        <%- include('../partials/navbar') %>
            <main>
                <section class="page-hero">
                    <div class="container">
                        <span class="section-badge">
                            ⚡ Our Services
                        </span>
                        <h1>
                            Professional Electrical Services
                        </h1>
                        <p>
                            Reliable electrical solutions for homes,
                            shops and commercial buildings.
                        </p>
                    </div>
                </section>
                <section class="services">
                    <div class="container">
                        <div class="services-grid">
                            <div class="service-card">
                                <div class="icon">🏠</div>
                                <h3>House Wiring</h3>
                                <p>
                                    Complete house wiring, rewiring and electrical fitting.
                                </p>
                            </div>
                            <div class="service-card">
                                <div class="icon">💡</div>
                                <h3>LED Installation</h3>
                                <p>
                                    Installation of LED lights, panels and tube lights.
                                </p>
                            </div>
                            <div class="service-card">
                                <div class="icon">🪭</div>
                                <h3>Fan Repair</h3>
                                <p>
                                    Ceiling fan installation and repair services.
                                </p>
                            </div>
                            <div class="service-card">
                                <div class="icon">❄</div>
                                <h3>Cooler Repair</h3>
                                <p>
                                    Repair and maintenance of air coolers.
                                </p>
                            </div>
                            <div class="service-card">
                                <div class="icon">🔌</div>
                                <h3>Switch Board Repair</h3>
                                <p>
                                    Repair and replacement of damaged switch boards.
                                </p>
                            </div>
                            <div class="service-card">
                                <div class="icon">🎇</div>
                                <h3>Decorative Lighting</h3>
                                <p>
                                    Festival lighting and decorative electrical setup.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
                <section class="why-us">
                    <div class="container">
                        <h2>
                            Why Choose Us?
                        </h2>
                        <div class="why-grid">
                            <div>✔ Experienced Electrician</div>
                            <div>✔ Fast Response</div>
                            <div>✔ Affordable Pricing</div>
                            <div>✔ Quality Work</div>
                        </div>
                    </div>
                </section>
                <section class="service-cta">
                    <div class="container">
                        <h2>
                            Need an Electrician?
                        </h2>
                        <p>
                            Call us today or book a service online.
                        </p>
                        <div class="hero-buttons">
                            <a href="#" class="btn btn-primary">
                                📞 Call Now
                            </a>
                            <a href="#" class="btn btn-secondary">
                                Book Service
                            </a>
                        </div>
                    </div>
                </section>
            </main>

            <%- include('../partials/footer') %>

            <script src="/js/navbar.js"></script>
