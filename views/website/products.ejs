<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head', { title: "Products" }) %>

<body>

    <%- include('../partials/navbar') %>

    <main>
        <!-- Page Hero -->
        <section class="products-hero">
            <div class="container">
                <span class="section-badge">
                    ⚡ Our Products
                </span>
                <h1>Quality Electrical Products</h1>
                <p>
                    Explore our wide range of electrical products for homes,
                    offices, and commercial projects.
                </p>
            </div>
        </section>

        <!-- Search -->
        <section class="search-section">
            <div class="container">
                <div class="search-box">
                    <svg xmlns="http://www.w3.org/2000/svg"
                        width="22"
                        height="22"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round">
                        <path d="m21 21-4.34-4.34"/>
                        <circle cx="11" cy="11" r="8"/>
                    </svg>
                    <input
                        type="search"
                        placeholder="Search products...">
                </div>
            </div>
        </section>

        <!-- Categories -->

        <section class="categories">
            <div class="container">
                <div class="category-list">
                    <button class="active">All</button>
                    <button>Lighting</button>
                    <button>Wires</button>
                    <button>Switches</button>
                    <button>Sockets</button>
                    <button>Protection</button>
                    <button>Accessories</button>
                    <button>Decorative</button>
                </div>
            </div>
        </section>

        <!-- Products -->

        <section class="products">
            <div class="container">
                <div class="products-grid">
                    
                    <% products.forEach(product => { %>
                        <div class="product-card">
                            <img src="<%= product.image || ''%>"
                                alt="Product">
                            <span class="product-category">
                                <%= product.category %>
                            </span>
                            <h3><%= product.name %></h3>
                            <p class="price">
                                ₹<%= product.price %>
                            </p>
                            <a href="/products/view-detail/<%=product._id%>" class="btn btn-primary">
                                View Details
                            </a>
                        </div>
                    <% }) %>
                </div>
            </div>
        </section>
    </main>

    <%- include('../partials/footer') %>
    
    <script src="/js/navbar.js"></script>

</body>

</html>