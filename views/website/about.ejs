<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head',{title:"About Us"}) %>

<body>

<%- include('../partials/navbar') %>

<main>
    <!-- Hero -->
    <section class="page-hero">
        <div class="container">
            <span class="section-badge">
                ⚡ About Us
            </span>
            <h1>Trusted Electrical Solutions</h1>
            <p>
                Delivering reliable electrical services and quality products
                for homes, shops and businesses.
            </p>
        </div>
    </section>

    <!-- About -->
    <section class="about">
        <div class="container">
            <div class="about-wrapper">
                <div class="about-image">
                    <img src="/images/about/about.jpg"
                        alt="Rudra Electrical">
                </div>
                <div class="about-content">
                    <h2>Who We Are</h2>
                    <p>
                        Rudra Electrical is a trusted local electrical shop
                        providing quality electrical products and professional
                        repair services. From house wiring and fan repair to
                        decorative lighting and electrical accessories, we
                        ensure safe, reliable and affordable solutions.
                    </p>
                    <p>
                        Our goal is to deliver honest service, quality products
                        and complete customer satisfaction.
                    </p>
                    <div class="about-points">
                        <div>✔ Experienced Electrician</div>
                        <div>✔ Genuine Electrical Products</div>
                        <div>✔ Affordable Prices</div>
                        <div>✔ Fast & Reliable Service</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->

    <section class="stats">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-card">
                    <h2>10+</h2>
                    <p>Years of Experience</p>
                </div>
                <div class="stat-card">
                    <h2>1000+</h2>
                    <p>Happy Customers</p>
                </div>
                <div class="stat-card">
                    <h2>1500+</h2>
                    <p>Projects Completed</p>
                </div>
                <div class="stat-card">
                    <h2>100%</h2>
                    <p>Customer Satisfaction</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission -->

    <section class="mission">
        <div class="container">
            <h2>Our Mission</h2>
            <p>
                To provide reliable electrical services and high-quality
                electrical products while maintaining honesty,
                professionalism and customer satisfaction.
            </p>
        </div>
    </section>

    <!-- CTA -->

    <section class="about-cta">
        <div class="container">
            <h2>Need Electrical Services?</h2>
            <p>
                Contact us today for wiring, repairs,
                installations and quality electrical products.
            </p>
            <div class="hero-buttons">
                <a href="tel:+919999999999"
                    class="btn btn-primary">
                    📞 Call Now
                </a>
                <a href="/booking"
                    class="btn btn-secondary">
                    Book Service
                </a>
            </div>
        </div>
    </section>
</main>
<%- include('../partials/footer') %>
<script src="/js/navbar.js"></script>
</body>

</html>