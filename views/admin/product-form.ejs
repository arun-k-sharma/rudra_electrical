<!DOCTYPE html>
<html lang="en">

<%- include('./partials/head',{title:"Add Product"}) %>

<body>

<div class="admin-layout container">

    <%- include('./partials/sidebar', {
        currentPage: 'products'
    }) %>

    <div class="admin-content">

        <%- include('./partials/header',{
            pageTitle:"Add Product",
            admin
        }) %>

        <main class="product-form-page">

            <div class="form-card">

                <h2>Add New Product</h2>

                <form
                    action="/admin/products/add-product"
                    method="POST"
                    enctype="multipart/form-data">

                    <div class="form-grid">

                        <div class="form-group">

                            <label>Product Image</label>

                            <input
                                type="file"
                                name="image"
                                accept="image/*"
                                required>

                        </div>

                        <div class="form-group">

                            <label>Product Name</label>

                            <input
                                type="text"
                                name="name"
                                placeholder="LED Bulb"
                                required>

                        </div>

                        <div class="form-group">

                            <label>Category</label>

                            <select name="category">

                                <option>Lighting</option>

                                <option>Wire</option>

                                <option>Switch</option>

                                <option>MCB</option>

                                <option>Fan</option>

                                <option>Accessories</option>

                            </select>

                        </div>

                        <div class="form-group">

                            <label>Price (₹)</label>

                            <input
                                type="number"
                                name="price"
                                required>

                        </div>

                        <div class="form-group">

                            <label>Stock</label>

                            <input
                                type="number"
                                name="stock"
                                required>

                        </div>

                    </div>

                    <div class="form-group">

                        <label>Description</label>

                        <textarea
                            rows="5"
                            name="description"></textarea>

                    </div>

                    <div class="checkbox">

                        <input
                            type="checkbox"
                            name="featured">

                        <label>

                            Featured Product

                        </label>

                    </div>

                    <h3>Specifications</h3>

                    <div class="form-grid">

                        <div class="form-group">

                            <label>Brand</label>

                            <input
                                type="text"
                                name="specifications[brand]">

                        </div>

                        <div class="form-group">

                            <label>Power</label>

                            <input
                                type="text"
                                name="specifications[power]">

                        </div>

                        <div class="form-group">

                            <label>Voltage</label>

                            <input
                                type="text"
                                name="specifications[voltage]">

                        </div>

                        <div class="form-group">

                            <label>Color</label>

                            <input
                                type="text"
                                name="specifications[color]">

                        </div>

                        <div class="form-group">

                            <label>Warranty</label>

                            <input
                                type="text"
                                name="specifications[warranty]">

                        </div>

                    </div>

                    <div class="button-group">

                        <a
                            href="/admin/products"
                            class="cancel-btn">

                            Cancel

                        </a>

                        <button
                            type="submit"
                            class="save-btn">

                            Save Product

                        </button>

                    </div>

                </form>

            </div>

        </main>

    </div>

</div>
    <script src="/js/sidebar.js"></script>
</body>

</html>