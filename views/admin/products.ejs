<!DOCTYPE html>
<html lang="en">

<%- include('./partials/head',{title:"Products"}) %>

    <body>

        <div class="admin-layout">

            <%- include('./partials/sidebar') %>

                <div class="admin-content container">

                    <%- include('./partials/header',{ pageTitle:"Products", admin}) %>

                        <main class="products-page">
                            <div class="page-top">
                                <h2>Manage Products</h2>
                                <a href="/admin/products/add-product" class="add-btn">
                                    + Add Product
                                </a>
                            </div>
                            <div class="table-wrapper">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Image</th>
                                            <th>Name</th>
                                            <th>Category</th>
                                            <th>Price</th>
                                            <th>Stock</th>
                                            <th>Featured</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>

                                        <% products.forEach(product=> { %>

                                            <tr>
                                                <td>
                                                    <img src="<%= product.image.url || '/images/products/circuit.avif' %>"
                                                        class="product-img">
                                                </td>
                                                <td>
                                                    <%= product.name %>
                                                </td>
                                                <td>
                                                    <%= product.category %>
                                                </td>
                                                <td>₹<%= product.price %>
                                                </td>
                                                <td>
                                                    <%= product.stock %>
                                                </td>
                                                <td>
                                                    <span class="badge success">
                                                        Yes
                                                    </span>
                                                </td>
                                                <td>
                                                    <a href="/admin/products/edit/<%= product._id %>" class="edit-btn">
                                                        Edit
                                                    </a>
                                                    <button class="delete-btn">
                                                        Delete
                                                    </button>
                                                </td>
                                            </tr>

                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </main>
                </div>
        </div>
        <script src="/js/sidebar.js"></script>

    </body>

</html>