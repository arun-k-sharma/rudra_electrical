<!DOCTYPE html>
<html lang="en">

<%- include('./partials/head',{title:"Products"}) %>

    <body>

        <div class="admin-layout">

            <%- include('./partials/sidebar') %>

                <div class="admin-content container">

                    <%- include('./partials/header',{ pageTitle:"Products", admin}) %>

                        <main class="products-page">
                            <div class="page-top">
                                <h2>Manage Products</h2>
                                <a href="/admin/products/add-product" class="add-btn">
                                    + Add Product
                                </a>
                            </div>
                            <div class="table-wrapper">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Image</th>
                                            <th>Name</th>
                                            <th>Category</th>
                                            <th>Price</th>
                                            <th>Stock</th>
                                            <th>Featured</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>

                                        <% products.forEach(product=> { %>

                                            <tr>
                                                <td>
                                                    <img src="<%= product.image.url || '/images/products/placeholder.jpg' %>"
                                                        class="product-img" loading="lazy">
                                                </td>
                                                <td>
                                                    <%= product.name %>
                                                </td>
                                                <td>
                                                    <%= product.category %>
                                                </td>
                                                <td>₹<%= product.price %>
                                                </td>
                                                <td>
                                                    <%= product.stock %>
                                                </td>
                                                <td>
                                                    <span class="badge <%= product.featured ? 'success' : 'failed' %>">
                                                        <%= product.featured ? 'Yes' : 'No' %>
                                                    </span>
                                                </td>
                                                <td>

                                                    <form action="/admin/products/delete/<%= product._id %>"
                                                        method="POST" onsubmit="return confirmDelete()">

                                                        <button type="submit" class="delete-btn">

                                                            Delete

                                                        </button>

                                                    </form>

                                                </td>
                                            </tr>

                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </main>
                </div>
        </div>





        <script src="/js/sidebar.js"></script>
        <script>
            function confirmDelete() {
                return confirm("Are you sure you want to delete this product?");
            }
        </script>

    </body>

</html>