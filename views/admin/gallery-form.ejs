<!DOCTYPE html>
<html lang="en">

<%- include('./partials/head',{title:"Upload Image"}) %>

    <body>

        <div class="admin-layout container">

            <%- include('./partials/sidebar') %>

                <div class="admin-content">

                    <%- include('./partials/header',{ pageTitle:"Upload Gallery Image", admin }) %>

                        <main class="gallery-form-page">

                            <div class="form-card">

                                <h2>Upload New Image</h2>

                                <form action="/admin/gallery/add" method="POST" enctype="multipart/form-data">

                                    <div class="form-group">

                                        <label>Image</label>

                                        <input type="file" name="image" accept="image/*" required>

                                    </div>

                                    <div class="form-group">

                                        <label>Title</label>

                                        <input type="text" name="title" placeholder="House Wiring" required>

                                    </div>

                                    <div class="form-group">

                                        <label>Category</label>

                                        <select name="category">

                                            <option>House Wiring</option>

                                            <option>Lighting</option>

                                            <option>Repairs</option>

                                            <option>Decoration</option>

                                            <option>Installation</option>

                                        </select>

                                    </div>

                                    <div class="form-group">

                                        <label>Description</label>

                                        <textarea rows="5" name="description"
                                            placeholder="Write something..."></textarea>

                                    </div>

                                    <div class="button-group">

                                        <a href="/admin/gallery" class="cancel-btn">

                                            Cancel

                                        </a>

                                        <button type="submit" class="save-btn">

                                            Upload Image

                                        </button>

                                    </div>

                                </form>

                            </div>

                        </main>

                </div>

        </div>

        <script src="/js/sidebar.js"></script>
    </body>

</html>