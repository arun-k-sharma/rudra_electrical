<!DOCTYPE html>
<html lang="en">

<%- include('./partials/head',{title:"Booking Details"}) %>

    <body>

        <% console.log(booking._id) %>

            <div class="admin-layout container">

                <%- include('./partials/sidebar', { admin: admin, currentPage: "bookings" }) %>

                    <div class="admin-content">

                        <%- include('./partials/header',{ pageTitle:"Booking Details" }) %>

                            <main class="booking-details-page">

                                <div class="booking-card">

                                    <div class="card-header">

                                        <h2>Customer Booking</h2>

                                        <a href="/admin/bookings" class="back-btn">

                                            ← Back

                                        </a>

                                    </div>

                                    <form action="/admin/bookings/<%= booking._id %>" method="POST">

                                        <div class="form-grid">

                                            <div class="form-group">

                                                <label>Customer Name</label>

                                                <input type="text" value="<%= booking.fullName %>" readonly>

                                            </div>

                                            <div class="form-group">

                                                <label>Phone Number</label>

                                                <input type="text" value="<%= booking.number %>" readonly>

                                            </div>

                                            <div class="form-group">

                                                <label>Service</label>

                                                <input type="text" value="<%= booking.service %>" readonly>

                                            </div>

                                            <div class="form-group">

                                                <label>Preferred Date</label>

                                                <input type="text" value="<%= booking.date.toLocaleDateString() %> "
                                                    readonly>

                                            </div>

                                        </div>

                                        <div class="form-group">

                                            <label>Address</label>

                                            <textarea rows="3" readonly>
<%= booking.address %>

                        </textarea>

                                        </div>

                                        <div class="form-group">

                                            <label>Problem Description</label>

                                            <textarea rows="6" readonly>
<%= booking.problemDescription %>
                        </textarea>

                                        </div>

                                        <div class="form-group">

                                            <label>Status</label>

                                            <select name="status">

                                                <option value="Pending" <%=booking.status==='Pending' ? 'selected' : ''
                                                    %>>Pending</option>

                                                <option>Completed</option>

                                                <option>Cancelled</option>

                                            </select>

                                        </div>

                                        <div class="button-group">

                                            <a href="/admin/bookings" class="cancel-btn">

                                                Cancel

                                            </a>

                                            <button type="submit" class="save-btn">

                                                Save Changes

                                            </button>

                                        </div>

                                    </form>

                                </div>

                            </main>

                    </div>

            </div>
            <script src="/js/sidebar.js"></script>
    </body>

</html>