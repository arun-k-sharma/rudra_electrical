<!DOCTYPE html>
<html lang="en">

<%- include('./partials/head',{title:"Gallery"}) %>

    <body>

        <div class="admin-layout container">

            <%- include('./partials/sidebar', { admin: admin, currentPage: "gallery" }) %>

                <div class="admin-content">

                    <%- include('./partials/header',{ pageTitle:"Gallery", }) %>

                        <main class="gallery-page">

                            <div class="page-top">

                                <h2>Manage Gallery</h2>

                                <a href="/admin/gallery/add" class="add-btn">

                                    + Upload Image

                                </a>

                            </div>

                            <div class="gallery-grid">

                                <% galleryImages.forEach((image)=> { %>
                                    <div class="gallery-card">

                                        <img src="<%= image.image.url || '/images/products/placeholder.jpg' %>"
                                            alt="Gallery" loading="lazy">

                                        <div class="gallery-info">

                                            <h4>
                                                <%= image.title || 'Not Awailable' %>
                                            </h4>

                                            <form action="/admin/gallery/delete/<%=image._id %>" method="POST">
                                                <button type="submit" class="delete-btn" onclick="return confirm('Are you sure you want to delete this image?');">

                                                    Delete

                                                </button>
                                            </form>


                                        </div>

                                    </div>

                                    <% }) %>

                            </div>

                        </main>

                </div>

        </div>
        <script src="/js/sidebar.js"></script>
    </body>

</html>